# ─── App metadata ─────────────────────────────────────
VITE_APP_NAME=SaccoFlow
VITE_APP_VERSION=1.0.0

# ─── Supabase ─────────────────────────────────────────
# Get these from https://app.supabase.com → Project Settings → API
# - URL                 → e.g. https://abcd1234.supabase.co
# - Publishable key     → e.g. sb_publishable_xxx (or legacy JWT anon key)
#
# Note: Vite requires the VITE_ prefix for any env var the client reads.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx_or_legacy_anon_jwt

# ─── Spring Boot backend (optional fallback) ──────────
VITE_API_BASE_URL=http://localhost:8080/api
